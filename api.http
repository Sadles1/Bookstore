### Bookstore API - IntelliJ HTTP Client sample requests
### Base URL
@baseUrl = http://localhost:8080

###############################################################################
# US1 - GET /books - List all books
###############################################################################

### US1 - List all books (initially empty)
GET {{baseUrl}}/books
Accept: application/json

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(Array.isArray(response.body), "Expected array body");
client.assert(response.body.length === 0, "Expected empty list");
%}

###############################################################################
# US2 - POST /books - Create a book
###############################################################################

### US2 - Create book "Clean Code" (success → 201)
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780132350884",
  "title": "Clean Code",
  "author": "Robert C. Martin",
  "price": 34.99,
  "image": "https://example.com/images/clean-code.jpg"
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
client.assert(response.body.title === "Clean Code", "Expected correct title");
client.assert(response.body.author === "Robert C. Martin", "Expected correct author");
client.assert(response.body.image === "https://example.com/images/clean-code.jpg", "Expected correct image");
client.assert(response.headers.valueOf("Location").includes("/books/9780132350884"), "Expected Location header");
%}

### US2 - ERROR: Duplicate ISBN (→ 409 Conflict)
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780132350884",
  "title": "Clean Code Duplicate",
  "author": "Robert C. Martin",
  "price": 34.99,
  "image": "https://example.com/images/clean-code.jpg"
}

> {%
client.assert(response.status === 409, "Expected HTTP 409");
client.assert(response.body.error === "CONFLICT", "Expected error=CONFLICT");
%}

### US2 - ERROR: Missing required fields (→ 400 Bad Request)
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "",
  "title": "",
  "author": "Some Author"
}

> {%
client.assert(response.status === 400, "Expected HTTP 400");
client.assert(response.body.error === "VALIDATION_ERROR", "Expected error=VALIDATION_ERROR");
%}

### US2 - ERROR: Price below minimum (→ 400 Bad Request)
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780000000001",
  "title": "Free Book",
  "author": "Some Author",
  "price": 0.00,
  "image": "https://example.com/images/free.jpg"
}

> {%
client.assert(response.status === 400, "Expected HTTP 400");
client.assert(response.body.error === "VALIDATION_ERROR", "Expected error=VALIDATION_ERROR");
%}

### US2 - ERROR: Invalid image URL (→ 400 Bad Request)
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780000000002",
  "title": "Bad URL Book",
  "author": "Some Author",
  "price": 9.99,
  "image": "not-a-valid-url"
}

> {%
client.assert(response.status === 400, "Expected HTTP 400");
client.assert(response.body.error === "VALIDATION_ERROR", "Expected error=VALIDATION_ERROR");
%}

### US1 - List all books (now shows created books)
GET {{baseUrl}}/books
Accept: application/json

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(Array.isArray(response.body), "Expected array body");
client.assert(response.body.length === 1, "Expected exactly 1 book");
client.assert(response.body[0].isbn === "9780132350884", "Expected Clean Code");
%}

###############################################################################
# US3 - GET /books/{isbn} - Get book by ISBN
###############################################################################

### US3 - Get existing book (→ 200)
GET {{baseUrl}}/books/9780132350884
Accept: application/json

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
client.assert(response.body.title === "Clean Code", "Expected correct title");
client.assert(response.body.author === "Robert C. Martin", "Expected correct author");
%}

### US3 - Get existing book with English language preference (→ 200)
GET {{baseUrl}}/books/9780132350884
Accept: application/json
Accept-Language: en

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
%}

### US3 - Get existing book with Portuguese language preference (→ 200)
GET {{baseUrl}}/books/9780132350884
Accept: application/json
Accept-Language: pt-PT

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
%}

### US3 - ERROR: Book not found - English error message (→ 404)
GET {{baseUrl}}/books/9999999999999
Accept: application/json
Accept-Language: en

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");
client.assert(
    response.body.message === "Book with ISBN 9999999999999 not found",
    "Expected English error message"
);
client.assert(
    response.headers.valueOf("Content-Language") === "en",
    "Expected Content-Language: en"
);
%}

### US3 - ERROR: Book not found - Portuguese error message (→ 404)
GET {{baseUrl}}/books/9999999999999
Accept: application/json
Accept-Language: pt

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");
client.assert(
    response.body.message === "Livro com ISBN 9999999999999 não encontrado",
    "Expected Portuguese error message"
);
client.assert(
    response.headers.valueOf("Content-Language") === "pt",
    "Expected Content-Language: pt"
);
%}

### US3 - ERROR: Book not found - Portuguese (pt-PT variant) error message (→ 404)
GET {{baseUrl}}/books/9999999999999
Accept: application/json
Accept-Language: pt-PT,pt;q=0.9,en;q=0.8

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(
    response.body.message === "Livro com ISBN 9999999999999 não encontrado",
    "Expected Portuguese error message for pt-PT variant"
);
client.assert(
    response.headers.valueOf("Content-Language") === "pt",
    "Expected Content-Language: pt"
);
%}

### US3 - ERROR: Book not found - no Accept-Language defaults to English (→ 404)
GET {{baseUrl}}/books/9999999999999
Accept: application/json

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(
    response.body.message === "Book with ISBN 9999999999999 not found",
    "Expected English message when no Accept-Language header"
);
client.assert(
    response.headers.valueOf("Content-Language") === "en",
    "Expected Content-Language: en"
);
%}

###############################################################################
# US4 - PUT /books/{isbn} - Full replace or create (upsert)
###############################################################################

### US4 - Replace existing book (→ 200 OK)
PUT {{baseUrl}}/books/9780132350884
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780132350884",
  "title": "Clean Code (Updated Edition)",
  "author": "Robert C. Martin",
  "price": 38.99,
  "image": "https://example.com/images/clean-code-updated.jpg"
}

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
client.assert(response.body.title === "Clean Code (Updated Edition)", "Expected updated title");
client.assert(response.body.image === "https://example.com/images/clean-code-updated.jpg", "Expected updated image");
%}

### US4 - Create new book via PUT (→ 201 Created with Location)
PUT {{baseUrl}}/books/9780134685991
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780134685991",
  "title": "Effective Java",
  "author": "Joshua Bloch",
  "price": 49.99,
  "image": "https://example.com/images/effective-java.jpg"
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.isbn === "9780134685991", "Expected correct ISBN");
client.assert(response.body.title === "Effective Java", "Expected correct title");
client.assert(response.headers.valueOf("Location").includes("/books/9780134685991"), "Expected Location header");
%}

### US4 - ERROR: Validation failure on PUT (→ 400 Bad Request)
PUT {{baseUrl}}/books/9780000000099
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780000000099",
  "title": "",
  "author": "",
  "price": -5.00,
  "image": "not-a-url"
}

> {%
client.assert(response.status === 400, "Expected HTTP 400");
client.assert(response.body.error === "VALIDATION_ERROR", "Expected error=VALIDATION_ERROR");
%}


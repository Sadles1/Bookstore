# US6 - DELETE /books/{isbn} - Delete book and its reviews
###############################################################################

### US6 - Create a temporary book to delete
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780000000099",
  "title": "Book To Delete",
  "author": "Temp Author",
  "price": 9.99,
  "image": "https://example.com/images/temp.jpg"
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.isbn === "9780000000099", "Expected correct ISBN");
%}

### US6 - Delete the temporary book (→ 204 No Content)
DELETE {{baseUrl}}/books/9780000000099

> {%
client.assert(response.status === 204, "Expected HTTP 204");
%}

### US6 - ERROR: Delete non-existent book (→ 404)
DELETE {{baseUrl}}/books/0000000000000

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");
%}


###############################################################################
# US8 - POST /books/{isbn}/reviews - Create a review
# Review IDs assigned sequentially: Clean Code → 1, 2; Pragmatic Programmer → 3
###############################################################################

### US8 - Create first review for "Clean Code" (→ 201)
POST {{baseUrl}}/books/9780132350884/reviews
Content-Type: application/json
Accept: application/json

{
  "rating": 5,
  "comment": "An absolute must-read for any software developer. Changed how I write code."
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.id === 1, "Expected review id=1");
client.assert(response.body.rating === 5, "Expected rating 5");
client.assert(response.body.comment !== null, "Expected non-null comment");
client.assert(response.headers.valueOf("Location").includes("/reviews/1"), "Expected Location header");
%}

### US8 - Create second review without comment (→ 201)
POST {{baseUrl}}/books/9780132350884/reviews
Content-Type: application/json
Accept: application/json

{
  "rating": 4
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.id === 2, "Expected review id=2");
client.assert(response.body.rating === 4, "Expected rating 4");
client.assert(response.body.comment === null, "Expected null comment");
%}

### US8 - Create review with comment for "Pragmatic Programmer" (→ 201)
POST {{baseUrl}}/books/9780201616224/reviews
Content-Type: application/json
Accept: application/json

{
  "rating": 5,
  "comment": "Timeless advice. Highly recommended for developers at all levels."
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
client.assert(response.body.id === 3, "Expected review id=3");
client.assert(response.body.rating === 5, "Expected rating 5");
client.assert(response.headers.valueOf("Location").includes("/reviews/3"), "Expected Location header");
%}

### US7 - List reviews for "Clean Code" (now has 2 reviews)
GET {{baseUrl}}/books/9780132350884/reviews
Accept: application/json

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(Array.isArray(response.body), "Expected array body");
client.assert(response.body.length === 2, "Expected exactly 2 reviews");
%}

### US8 - ERROR: Create review for non-existent book (→ 404)
POST {{baseUrl}}/books/0000000000000/reviews
Content-Type: application/json
Accept: application/json

{
  "rating": 3,
  "comment": "This book does not exist"
}

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");

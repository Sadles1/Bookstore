###############################################################################
# US5 - PATCH /books/{isbn} - Partial update
###############################################################################

### US5 - Update only the price (→ 200)
PATCH {{baseUrl}}/books/9780132350884
Content-Type: application/json
Accept: application/json

{
  "price": 29.99
}

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780132350884", "Expected correct ISBN");
client.assert(String(response.body.price).startsWith("29.99"), "Expected updated price 29.99");
%}

### US5 - Update title and author (→ 200)
PATCH {{baseUrl}}/books/9780201616224
Content-Type: application/json
Accept: application/json

{
  "title": "The Pragmatic Programmer: 20th Anniversary Edition",
  "author": "David Thomas, Andrew Hunt"
}

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780201616224", "Expected correct ISBN");
client.assert(response.body.title === "The Pragmatic Programmer: 20th Anniversary Edition", "Expected updated title");
client.assert(response.body.author === "David Thomas, Andrew Hunt", "Expected updated author");
%}

### US5 - Update image URL (→ 200)
PATCH {{baseUrl}}/books/9780201616224
Content-Type: application/json
Accept: application/json

{
  "image": "https://example.com/images/pragmatic-programmer-new.jpg"
}

> {%
client.assert(response.status === 200, "Expected HTTP 200");
client.assert(response.body.isbn === "9780201616224", "Expected correct ISBN");
client.assert(response.body.image === "https://example.com/images/pragmatic-programmer-new.jpg", "Expected updated image");
%}

### US5 - ERROR: Book not found (→ 404)
PATCH {{baseUrl}}/books/0000000000000
Content-Type: application/json
Accept: application/json

{
  "price": 9.99
}

> {%
client.assert(response.status === 404, "Expected HTTP 404");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");
%}

### US5 - ERROR: Invalid field value in PATCH (→ 400)
PATCH {{baseUrl}}/books/9780132350884
Content-Type: application/json
Accept: application/json

{
  "price": 0.00
}

> {%
client.assert(response.status === 400, "Expected HTTP 400");
client.assert(response.body.error === "VALIDATION_ERROR", "Expected error=VALIDATION_ERROR");

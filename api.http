###############################################################################
# US6 - Cascade delete: verify reviews are removed when book is deleted
###############################################################################

### US6 Cascade - Create a book with a review to test cascade delete
POST {{baseUrl}}/books
Content-Type: application/json
Accept: application/json

{
  "isbn": "9780000000100",
  "title": "Book For Cascade Test",
  "author": "Temp Author",
  "price": 9.99,
  "image": "https://example.com/images/cascade.jpg"
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
%}

### US6 Cascade - Add a review to that book
POST {{baseUrl}}/books/9780000000100/reviews
Content-Type: application/json
Accept: application/json

{
  "rating": 3,
  "comment": "Review to be cascade-deleted"
}

> {%
client.assert(response.status === 201, "Expected HTTP 201");
%}

### US6 Cascade - Delete the book
DELETE {{baseUrl}}/books/9780000000100

> {%
client.assert(response.status === 204, "Expected HTTP 204");
%}

### US6 Cascade - Verify reviews are gone (→ 404, book no longer exists)
GET {{baseUrl}}/books/9780000000100/reviews
Accept: application/json

> {%
client.assert(response.status === 404, "Expected HTTP 404 - book and its reviews no longer exist");
client.assert(response.body.error === "NOT_FOUND", "Expected error=NOT_FOUND");
%}

